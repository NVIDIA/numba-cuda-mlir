# A utility script to install the correct packages and run the tests.

set -euo pipefail

echo "Installing numba-cuda-mlir wheel"
wheels=("${NUMBA_CUDA_MLIR_CUDA_ARTIFACTS_DIR}"/*.whl)
if [[ ${#wheels[@]} -ne 1 || ! -e "${wheels[0]}" ]]; then
  echo "Expected exactly one numba-cuda-mlir wheel in ${NUMBA_CUDA_MLIR_CUDA_ARTIFACTS_DIR}, found ${#wheels[@]}"
  printf '%s\n' "${wheels[@]}"
  exit 1
fi
wheel="${wheels[0]}"
pip_wheel="${wheel}"
if command -v cygpath >/dev/null 2>&1; then
  pip_wheel="$(cygpath -w "${wheel}")"
fi

coverage_packages=()
pytest_args=(-v --tb=short -W ignore::UserWarning --ignore=tests/benchmarks -n auto --dist loadscope)
if [[ "${NUMBA_CUDA_MLIR_COVERAGE:-0}" == "1" ]]; then
  coverage_packages=(pytest-cov coverage)
  pytest_args+=(--cov=numba-cuda-mlir --cov=cuda --cov-report=term-missing)
fi

CUDA_BINDINGS_SPEC="cuda-bindings==${TEST_CUDA_MAJOR}.${TEST_CUDA_MINOR}.*"
if [[ "${TEST_CUDA_MAJOR}.${TEST_CUDA_MINOR}" == "12.2" ]]; then
  CUDA_BINDINGS_SPEC="cuda-bindings>=12.9.1,<13.0.0"
fi

if [[ "${LOCAL_CTK}" == 1 ]]; then
  pip install "${pip_wheel}" --group "test-cu${TEST_CUDA_MAJOR}" \
    "${CUDA_BINDINGS_SPEC}" "cuda-core[cu${TEST_CUDA_MAJOR}]" \
    "${coverage_packages[@]}"
else
  pip install "${pip_wheel}[cu${TEST_CUDA_MAJOR}]" --group "test-cu${TEST_CUDA_MAJOR}" \
    "${CUDA_BINDINGS_SPEC}" "cuda-core[cu${TEST_CUDA_MAJOR}]" \
    "cuda-toolkit[cccl,cudart]==${TEST_CUDA_MAJOR}.${TEST_CUDA_MINOR}.*" \
    "${coverage_packages[@]}"
fi

if [[ "${RUNNER_OS:-}" == "Windows" || "$(python - <<'PY'
import os
print(os.name)
PY
)" == "nt" ]]; then
  echo "Debugging Windows MLIR native import"
  python - <<'PY'
import ctypes
import glob
import importlib.util
import os
import pathlib
import struct
import sys
import traceback

print(f"Python executable: {sys.executable}")
print(f"Python version: {sys.version}")
print(f"PATH: {os.environ.get('PATH', '')}")

spec = importlib.util.find_spec("numba_cuda_mlir")
print(f"numba_cuda_mlir spec: {spec}")
if spec is None or not spec.submodule_search_locations:
    raise SystemExit(0)

pkg = pathlib.Path(next(iter(spec.submodule_search_locations)))
mlir_libs = pkg / "_mlir" / "_mlir_libs"
pkg_lib = pkg / "lib"
print(f"Package dir: {pkg}")
print(f"MLIR libs dir: {mlir_libs} exists={mlir_libs.is_dir()}")
print(f"Package lib dir: {pkg_lib} exists={pkg_lib.is_dir()}")

_dll_directory_handles = []
for directory in (mlir_libs, pkg, pkg_lib):
    if directory.is_dir():
        print(f"Adding DLL directory: {directory}")
        _dll_directory_handles.append(os.add_dll_directory(str(directory)))

if mlir_libs.is_dir():
    print("MLIR native files:")
    for path in sorted(mlir_libs.iterdir()):
        if path.is_file() and path.suffix.lower() in {".dll", ".pyd", ".lib", ".exp"}:
            print(f"  {path.name} size={path.stat().st_size}")

load_candidates = [
    mlir_libs / "nanobind-numba_cuda_mlir.dll",
    mlir_libs / "MLIRPythonSupport-numba_cuda_mlir.dll",
    mlir_libs / "MLIRPythonCAPI.dll",
    mlir_libs / "MLIRToLLVM70.dll",
    pkg / "MLIRToLLVM70.dll",
    pkg_lib / "LLVM.dll",
]
load_candidates.extend(pathlib.Path(p) for p in glob.glob(str(mlir_libs / "_mlir*.pyd")))

def _rva_to_offset(sections, rva):
    for virtual_address, virtual_size, raw_size, raw_pointer in sections:
        size = max(virtual_size, raw_size)
        if virtual_address <= rva < virtual_address + size:
            return raw_pointer + (rva - virtual_address)
    return None

def _read_c_string(data, offset):
    end = data.find(b"\0", offset)
    if end < 0:
        end = len(data)
    return data[offset:end].decode("ascii", errors="replace")

def _pe_imports(path):
    data = path.read_bytes()
    if data[:2] != b"MZ":
        return []
    pe_offset = struct.unpack_from("<I", data, 0x3C)[0]
    if data[pe_offset:pe_offset + 4] != b"PE\0\0":
        return []

    coff_offset = pe_offset + 4
    number_of_sections = struct.unpack_from("<H", data, coff_offset + 2)[0]
    optional_header_size = struct.unpack_from("<H", data, coff_offset + 16)[0]
    optional_offset = coff_offset + 20
    magic = struct.unpack_from("<H", data, optional_offset)[0]
    data_directory_offset = optional_offset + (112 if magic == 0x20B else 96)
    import_rva, _ = struct.unpack_from("<II", data, data_directory_offset + 8)

    sections = []
    section_offset = optional_offset + optional_header_size
    for i in range(number_of_sections):
        off = section_offset + i * 40
        virtual_size, virtual_address, raw_size, raw_pointer = struct.unpack_from("<IIII", data, off + 8)
        sections.append((virtual_address, virtual_size, raw_size, raw_pointer))

    import_offset = _rva_to_offset(sections, import_rva)
    if import_offset is None:
        return []

    imports = []
    descriptor_size = 20
    for i in range(2048):
        off = import_offset + i * descriptor_size
        original_first_thunk, _, _, name_rva, first_thunk = struct.unpack_from("<IIIII", data, off)
        if original_first_thunk == 0 and name_rva == 0 and first_thunk == 0:
            break
        name_offset = _rva_to_offset(sections, name_rva)
        if name_offset is not None:
            imports.append(_read_c_string(data, name_offset))
    return imports

for path in load_candidates:
    if path.exists() and path.suffix.lower() in {".dll", ".pyd"}:
        try:
            imports = _pe_imports(path)
            print(f"PE imports: {path.name}: {', '.join(imports) if imports else '<none>'}")
        except Exception as exc:
            print(f"PE imports failed: {path}: {exc!r}")

for path in load_candidates:
    if not path.exists():
        print(f"LOAD skip missing: {path}")
        continue
    try:
        ctypes.WinDLL(str(path))
        print(f"LOAD ok: {path}")
    except OSError as exc:
        print(f"LOAD failed: {path}")
        print(f"  winerror={getattr(exc, 'winerror', None)} errno={getattr(exc, 'errno', None)}")
        print(f"  {exc!r}")

try:
    from numba_cuda_mlir._mlir import ir
    print(f"MLIR ir import ok: {ir}")
except BaseException:
    print("MLIR ir import failed:")
    traceback.print_exc()
PY
fi

echo "Running numba-cuda-mlir tests"
${SANITIZER_CMD} pytest "${pytest_args[@]}"

if [[ "${NUMBA_CUDA_MLIR_COVERAGE:-0}" == "1" ]]; then
  echo "Generating markdown coverage report"
  if [[ -n "${GITHUB_STEP_SUMMARY:-}" ]]; then
    python -m coverage report --format markdown >> "${GITHUB_STEP_SUMMARY}"
  else
    python -m coverage report --format markdown
  fi
fi
